# iFrame Embedding (Content Security Policy)
# Comma-separated list of domains allowed to embed the booking pages via iframe.
# If omitted, defaults to 'self' only. 
# Example: ALLOWED_FRAME_ANCESTORS=https://your-website.com, https://another-site.com
ALLOWED_FRAME_ANCESTORS=

# Authentication Secrets
# AUTH_SECRET is used for staff NextAuth and fallback for parent sessions.
# AUTH_SECRET=your_super_secret_key
# PARENT_SESSION_SECRET is optionally used specifically for parent JWT sessions.
# PARENT_SESSION_SECRET=another_super_secret_key
